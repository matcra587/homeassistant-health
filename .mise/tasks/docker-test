#!/usr/bin/env bash
set -euo pipefail

image="${DOCKER_IMAGE:-homeassistant-health:test}"
retries="${DOCKER_TEST_RETRIES:-20}"
retry_delay="${DOCKER_TEST_RETRY_DELAY:-1}"
cid=""

cleanup() {
	status=$?
	if [[ -n "${cid}" ]]; then
		if ((status != 0)); then
			docker logs "${cid}" >&2 || true
		fi
		docker stop "${cid}" >/dev/null 2>&1 || true
	fi
	return "${status}"
}
trap cleanup EXIT

cid="$(docker run -d --rm -p 127.0.0.1::3000 "${image}")"
port="$(docker port "${cid}" 3000/tcp | awk -F: '{ print $2 }')"

if [[ -z "${port}" ]]; then
	echo "docker test failed: container port was not published" >&2
	exit 1
fi

curl --fail --silent --retry "${retries}" --retry-delay "${retry_delay}" --retry-connrefused --retry-all-errors "http://127.0.0.1:${port}/api/health"
curl -fsS "http://127.0.0.1:${port}/healthz" >/dev/null
curl -fsS "http://127.0.0.1:${port}/api/ready" | grep -qx "OK"
curl -fsS "http://127.0.0.1:${port}/readyz" | grep -qx "OK"
curl -fsS "http://127.0.0.1:${port}/" >/dev/null
