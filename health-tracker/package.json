{
  "name": "homeassistant-health-app",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run clean && bun build --target=bun --production --sourcemap=none --outdir=dist ./src/server/index.ts",
    "build:analyze": "bun run clean && bun build --target=bun --production --sourcemap=none --metafile=dist/metafile.json --outdir=dist ./src/server/index.ts",
    "check": "bun run typecheck && bun run lint && bun run test && bun run build",
    "clean": "rm -rf dist",
    "dev": "bun --watch src/server/index.ts",
    "format": "biome format --write src tests package.json tsconfig.json",
    "lint": "biome check src tests package.json tsconfig.json",
    "lint:fix": "biome check --write src tests package.json tsconfig.json",
    "start": "cd dist && NODE_ENV=production bun index.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@finegym/fitness-calc": "^1.0.1",
    "@mantine/charts": "^9.1.1",
    "@mantine/core": "^9.1.1",
    "@mantine/dates": "^9.1.1",
    "@mantine/form": "^9.1.1",
    "@mantine/hooks": "^9.1.1",
    "@mantine/notifications": "^9.1.1",
    "@tabler/icons-react": "^3.44.0",
    "dayjs": "^1.11.20",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@happy-dom/global-registrator": "^20.9.0",
    "@playwright/cli": "^0.1.13",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
